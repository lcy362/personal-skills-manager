#!/usr/bin/env bash
set -euo pipefail
shopt -s nullglob

resolve_psm_dir() {
  local self
  if [[ -L "$0" ]]; then
    self="$(readlink "$0")"
    [[ "$self" != /* ]] && self="$(dirname "$0")/$self"
  else
    self="$0"
  fi
  (cd "$(dirname "$self")/.." && pwd)
}
PSM_DIR="$(resolve_psm_dir)"
SKILLS_DIR="$PSM_DIR/skills"
PROJECT_SKILLS_DIR=".skills"

# ---- startup sanity check --------------------------------------------------
if [[ ! -d "$SKILLS_DIR" ]]; then
  echo "✖ pks: skills directory not found at $SKILLS_DIR" >&2
  echo "  Script location: $0" >&2
  echo "  Resolved PSM_DIR: $PSM_DIR" >&2
  echo "  Run 'which pks' to check which command is being executed." >&2
  echo "  If you just installed, run 'source ~/.zshrc' first." >&2
  exit 1
fi

print_error() { printf "\033[31m✖\033[0m %s\n" "$*" >&2; }
print_ok()    { printf "\033[32m✓\033[0m %s\n" "$*"; }
print_info()  { printf "\033[36mℹ\033[0m %s\n" "$*"; }
print_warn()  { printf "\033[33m⚠\033[0m %s\n" "$*" >&2; }

usage() {
  cat <<'EOF'
pks — Personal Skills Manager

USAGE
  pks list                      List all global skills
  pks new <name>                Create a new skill skeleton
  pks delete <name>             Permanently delete a global skill

  pks init                      Init .skills/ in current project
  pks status                    Show installed skills in current project
  pks available                 Show installable global skills (with project status)
  pks install <name>            Install a skill into current project
   pks uninstall <name>          Uninstall a skill from current project
   pks update <name>             Reinstall a skill (uninstall then reinstall from global)
   pks push <name>               Push project skill edits back to global skills

   pks agents                    List detected global agent skill directories
   pks project-agents            List project-level agent skill directories
   pks install-to <agent> <skill> Install a global skill to an agent's skill dir
   pks uninstall-from <agent> <skill> Remove a skill from an agent's skill dir
   pks update-to <agent> <skill>   Update a skill in agent dir from global skills

   pks link [agent]              Symlink agent(s) project skill dir → .skills/
   pks unlink [agent]            Remove symlinks from agent project skill dirs

   pks install-self              Install pks to system (~/.local/share/pks)
   pks doctor                    Show diagnostic info
  pks help                      Show this help
  pks version                   Show version
EOF
}

version() {
  echo "pks 1.0.0"
  echo "Personal Skills Manager"
}

# ---- INDEX.md rebuild ------------------------------------------------------
rebuild_index() {
  local index_file="$PROJECT_SKILLS_DIR/INDEX.md"
  {
    printf '%s\n' "# Personal Skills"
    printf '%s\n' ""
    printf '%s\n' "This directory contains AI agent skills installed for this project."
    printf '%s\n' "Agents: read the \`SKILL.md\` file in each skill directory below for relevant instructions."
    printf '%s\n' ""
    printf '%s\n' "## Installed Skills"
    printf '%s\n' ""

    local count=0
    for d in "$PROJECT_SKILLS_DIR"/*/; do
      local skillname; skillname="$(basename "$d")"
      [[ "$skillname" == _* ]] && continue
      count=$((count + 1))
      local sdesc="" sver=""
      [[ -f "$d/SKILL.md" ]] && sdesc="$(grep -m1 '^description:' "$d/SKILL.md" 2>/dev/null | sed 's/^description:[[:space:]]*//')"
      [[ -f "$d/SKILL.md" ]] && sver="$(grep -m1 '^version:' "$d/SKILL.md" 2>/dev/null | sed 's/^version:[[:space:]]*//')"
      printf -- "- **[%s](%s/SKILL.md)** — %s\n" "$skillname" "$skillname" "${sdesc:-No description}"
      printf "  Version: %s\n" "${sver:---}"
      printf "\n"
    done

    if [[ $count -eq 0 ]]; then
      printf '%s\n' "*(No skills installed yet. Run \`pks install <name>\` to add one.)*"
      printf '\n'
    fi
  } > "$index_file"
}

# ---- global skill operations -----------------------------------------------
cmd_list() {
  local any=0
  for skill_dir in "$SKILLS_DIR"/*/; do
    local name; name="$(basename "$skill_dir")"
    [[ "$name" == _* ]] && continue
    any=1
    local desc=""
    [[ -f "$skill_dir/SKILL.md" ]] && desc="$(grep -m1 '^description:' "$skill_dir/SKILL.md" 2>/dev/null | sed 's/^description:[[:space:]]*//')"
    printf "  \033[1m%s\033[0m\n" "$name"
    [[ -n "$desc" ]] && printf "    %s\n" "$desc"
  done
  if [[ $any -eq 0 ]]; then
    print_info "No skills found. Create one with: pks new <name>"
  fi
}

cmd_new() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    print_error "Usage: pks new <skill-name>"
    return 1
  fi
  local target="$SKILLS_DIR/$name"
  if [[ -d "$target" ]]; then
    print_error "Skill '$name' already exists at $target"
    return 1
  fi
  mkdir -p "$target/files"

  if [[ -f "$SKILLS_DIR/_template/SKILL.md" ]]; then
    sed "s/<skill-name>/$name/g" "$SKILLS_DIR/_template/SKILL.md" > "$target/SKILL.md"
  else
    cat > "$target/SKILL.md" <<SKILLEOF
---
name: $name
description: TODO: describe this skill
version: 0.1.0
---

# $name

TODO: describe what this skill does

## Usage

TODO: how agents should use this skill

## Files

- \`files/\`: additional files bundled with this skill
SKILLEOF
  fi

  print_ok "Created skill '$name' at $target"
  print_info "Edit $target/SKILL.md to add instructions"
}

cmd_delete() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    print_error "Usage: pks delete <skill-name>"
    return 1
  fi
  local target="$SKILLS_DIR/$name"
  if [[ ! -d "$target" ]]; then
    print_error "Skill '$name' not found at $target"
    return 1
  fi
  if [[ "$name" == _* ]]; then
    print_error "Cannot delete template (_*) skills"
    return 1
  fi
  rm -rf "$target"
  print_ok "Deleted skill '$name' from global skills"
}

# ---- project-level ---------------------------------------------------------
is_in_project() { [[ -d "$PROJECT_SKILLS_DIR" ]]; }

ensure_in_project() {
  if ! is_in_project; then
    print_error "Not in a pks-initialized project (no .skills/ directory found)"
    print_info "Run 'pks init' first"
    return 1
  fi
}

cmd_init() {
  if is_in_project; then
    print_info ".skills/ already initialized in $(pwd)"
    return 0
  fi
  mkdir -p "$PROJECT_SKILLS_DIR"
  rebuild_index
  print_ok "Initialized .skills/ in $(pwd)"
}

cmd_available() {
  ensure_in_project || return 1

  local installed=""
  for d in "$PROJECT_SKILLS_DIR"/*/; do
    local n; n="$(basename "$d")"
    [[ "$n" == _* ]] && continue
    installed="$installed $n"
  done

  local any=0
  for skill_dir in "$SKILLS_DIR"/*/; do
    local name; name="$(basename "$skill_dir")"
    [[ "$name" == _* ]] && continue
    any=1
    local desc="" ver=""
    [[ -f "$skill_dir/SKILL.md" ]] && desc="$(grep -m1 '^description:' "$skill_dir/SKILL.md" 2>/dev/null | sed 's/^description:[[:space:]]*//')"

    if [[ " $installed " == *" $name "* ]]; then
      [[ -f "$PROJECT_SKILLS_DIR/$name/SKILL.md" ]] && ver="$(grep -m1 '^version:' "$PROJECT_SKILLS_DIR/$name/SKILL.md" 2>/dev/null | sed 's/^version:[[:space:]]*//')"
      printf "  \033[32m✓\033[0m \033[1m%s\033[0m" "$name"
      [[ -n "$ver" ]] && printf " (\033[33m%s\033[0m)" "$ver"
      printf "\n"
    else
      printf "  \033[90m-\033[0m \033[1m%s\033[0m\n" "$name"
    fi
    [[ -n "$desc" ]] && printf "    %s\n" "$desc"
  done

  if [[ $any -eq 0 ]]; then
    print_info "No global skills available. Create one with: pks new <name>"
  fi
}

cmd_status() {
  ensure_in_project || return 1

  local count=0
  for d in "$PROJECT_SKILLS_DIR"/*/; do
    local name; name="$(basename "$d")"
    [[ "$name" == _* ]] && continue
    count=$((count + 1))
  done

  printf "Skills in \033[1m%s\033[0m:\n" "$(pwd)"
  if [[ $count -eq 0 ]]; then
    print_info "No skills installed. Run 'pks available' to see installable skills."
  else
    local i=0
    for d in "$PROJECT_SKILLS_DIR"/*/; do
      local name; name="$(basename "$d")"
      [[ "$name" == _* ]] && continue
      i=$((i + 1))
      local desc="" ver=""
      [[ -f "$d/SKILL.md" ]] && desc="$(grep -m1 '^description:' "$d/SKILL.md" 2>/dev/null | sed 's/^description:[[:space:]]*//')"
      [[ -f "$d/SKILL.md" ]] && ver="$(grep -m1 '^version:' "$d/SKILL.md" 2>/dev/null | sed 's/^version:[[:space:]]*//')"
      printf "  \033[32m✓\033[0m \033[1m%s\033[0m" "$name"
      [[ -n "$ver" ]] && printf " (\033[33m%s\033[0m)" "$ver"
      printf "\n"
      [[ -n "$desc" ]] && printf "    %s\n" "$desc"
    done
  fi

  local avail=0
  for skill_dir in "$SKILLS_DIR"/*/; do
    local n; n="$(basename "$skill_dir")"
    [[ "$n" == _* ]] && continue
    avail=$((avail + 1))
  done
  printf "\n"
  print_ok "$count skill(s) installed"
  print_info "$avail skill(s) available globally"
}

cmd_install() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    print_error "Usage: pks install <skill-name>"
    return 1
  fi

  ensure_in_project || return 1

  local src="$SKILLS_DIR/$name"
  if [[ ! -d "$src" ]]; then
    print_error "Skill '$name' not found in global skills"
    print_info "Available:"
    cmd_list
    return 1
  fi

  local dest="$PROJECT_SKILLS_DIR/$name"
  if [[ -d "$dest" ]]; then
    print_warn "Skill '$name' is already installed"
    return 0
  fi

  mkdir -p "$dest"
  cp -R "$src/"* "$dest/"
  print_ok "Installed skill '$name'"
  rebuild_index
  print_info "Updated $PROJECT_SKILLS_DIR/INDEX.md"
}

cmd_uninstall() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    print_error "Usage: pks uninstall <skill-name>"
    return 1
  fi

  ensure_in_project || return 1

  local dest="$PROJECT_SKILLS_DIR/$name"
  if [[ ! -d "$dest" ]]; then
    print_error "Skill '$name' is not installed in this project"
    return 1
  fi

  rm -rf "$dest"
  print_ok "Uninstalled skill '$name'"
  rebuild_index
  print_info "Updated $PROJECT_SKILLS_DIR/INDEX.md"
}

cmd_update() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    print_error "Usage: pks update <skill-name>"
    return 1
  fi

  ensure_in_project || return 1

  local dest="$PROJECT_SKILLS_DIR/$name"
  if [[ ! -d "$dest" ]]; then
    print_error "Skill '$name' is not installed in this project"
    return 1
  fi

  local src="$SKILLS_DIR/$name"
  if [[ ! -d "$src" ]]; then
    print_error "Skill '$name' not found in global skills — cannot reinstall"
    return 1
  fi

  rm -rf "$dest"
  print_ok "Uninstalled skill '$name'"

  mkdir -p "$dest"
  cp -R "$src/"* "$dest/"
  print_ok "Updated skill '$name' (reinstalled from global skills)"
  rebuild_index
  print_info "Updated $PROJECT_SKILLS_DIR/INDEX.md"
}

cmd_push() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    print_error "Usage: pks push <skill-name>"
    return 1
  fi

  ensure_in_project || return 1

  local src="$PROJECT_SKILLS_DIR/$name"
  if [[ ! -d "$src" ]]; then
    print_error "Skill '$name' is not installed in this project"
    return 1
  fi

  local dest="$SKILLS_DIR/$name"
  mkdir -p "$dest"
  cp -R "$src/"* "$dest/"
  print_ok "Pushed skill '$name' to global skills"
}

# ---- self-install ----------------------------------------------------------
cmd_install_self() {
  local target_home="${PKS_HOME:-$HOME/.local/share/pks}"
  local target_bin_dir="${PKS_BIN_DIR:-$HOME/.local/bin}"
  local target_bin="$target_bin_dir/pks"

  print_info "Installing to $target_home ..."
  mkdir -p "$target_home" "$target_bin_dir"

  # Copy entire PSM_DIR to target
  cp -R "$PSM_DIR/." "$target_home/"
  chmod +x "$target_home/bin/pks"

  # Create symlink
  rm -f "$target_bin"
  ln -s "$target_home/bin/pks" "$target_bin"
  print_ok "Symlink: $target_bin → $target_home/bin/pks"

  # Add to PATH
  local rc
  if [[ -n "${ZSH_VERSION:-}" ]]; then
    rc="$HOME/.zshrc"
  elif [[ -f "$HOME/.zshrc" ]]; then
    rc="$HOME/.zshrc"
  elif [[ -f "$HOME/.bashrc" ]]; then
    rc="$HOME/.bashrc"
  elif [[ -f "$HOME/.bash_profile" ]]; then
    rc="$HOME/.bash_profile"
  else
    rc="$HOME/.zshrc"
  fi

  # Prepend to PATH so ~/.local/bin takes priority over /usr/bin
  local marker="# pks PATH"
  if ! grep -qF "$target_bin_dir" "$rc" 2>/dev/null; then
    printf '\n%s\n%s\n%s\n' "# Added by pks" "export PATH=\"$target_bin_dir:\$PATH\"" "# pks PATH" >> "$rc"
    print_ok "Added $target_bin_dir to PATH (prepended) in $rc"
  fi

  print_ok "pks installed! Run 'source $rc' or restart terminal."
}

# ---- diagnostics -----------------------------------------------------------
cmd_doctor() {
  echo "pks doctor — diagnostics"
  echo ""
  printf "  %-20s %s\n" "Script path:" "$0"
  if [[ -L "$0" ]]; then
    printf "  %-20s %s\n" "Symlink target:" "$(readlink "$0")"
  fi
  printf "  %-20s %s\n" "PSM_DIR:" "$PSM_DIR"
  printf "  %-20s %s\n" "SKILLS_DIR:" "$SKILLS_DIR"
  printf "  %-20s %s\n" "Skills exist:" "$([[ -d "$SKILLS_DIR" ]] && echo 'yes' || echo 'NO!')"
  printf "  %-20s %s\n" "Shell:" "$SHELL"
  printf "  %-20s %s\n" "CWD:" "$(pwd)"
  printf "  %-20s %s\n" "which pks:" "$(command -v pks 2>/dev/null || echo 'not in PATH')"
  echo ""
  if [[ ! -d "$SKILLS_DIR" ]]; then
    echo "  ⚠ SKILLS_DIR missing — global commands (list/new/delete) won't work."
    echo "  If you installed via install.sh or 'pks install-self',"
    echo "  re-run the install from the repository directory."
    echo "  The skills/ directory must be alongside bin/pks."
  fi
}

# ---- agent skill directory commands ----------------------------------------

# Known agent skill directory mappings
resolve_agent_path() {
  local name="$1"
  case "$name" in
    .agents)       echo "$HOME/.agents/skills" ;;
    opencode)      echo "$HOME/.config/opencode/skills" ;;
    claude)        echo "$HOME/.claude/skills" ;;
    trae)          echo "$HOME/.trae/skills" ;;
    trae-cn)       echo "$HOME/.trae-cn/skills" ;;
    qoder)         echo "$HOME/.qoder/skills" ;;
    qoderwork)     echo "$HOME/.qoderwork/skills" ;;
    qoderworkcn)   echo "$HOME/.qoderworkcn/skills" ;;
    workbuddy)     echo "$HOME/.workbuddy/skills" ;;
    codex)         echo "$HOME/.codex/skills" ;;
    openclaw)      echo "$HOME/.openclaw/skills" ;;
    hermes)        echo "$HOME/.hermes/skills" ;;
    teamwork)      echo "$HOME/teamwork/skills" ;;
    cursor)        echo "$HOME/.cursor/skills" ;;
    windsurf)      echo "$HOME/.windsurf/skills" ;;
    *)             echo "" ;;
  esac
}

# ---- project-level agent skill directories ----------------------------------
#
# Which agents support project-level skills (SKILL.md inside the project)?
# Based on ecosystem research (Jul 2026):
#
#   agent       | project-level dir     | source / notes
#   ------------+-----------------------+----------------------------------------
#   opencode    | .opencode/skills/     | opencode.ai/docs/skills (official)
#   .agents     | .agents/skills/       | opencode + cursor docs (cross-agent std)
#   claude      | .claude/skills/       | opencode + cursor docs (compat layer)
#   cursor      | .cursor/skills/       | cursor.com/docs/skills (official)
#   windsurf    | .windsurf/skills/     | windsurf skill docs
#   trae        | .trae/skills/         | docs.trae.ai/ide/skills (official)
#   trae-cn     | .trae-cn/skills/      | same as trae, China variant
#   codex       | .codex/skills/        | cursor docs (compat for Codex CLI)
#   qoder       | .qoder/skills/        | inferred from global convention
#   qoderwork   | .qoderwork/skills/    | inferred from global convention
#   qoderworkcn | .qoderworkcn/skills/  | inferred from global convention
#   workbuddy   | .workbuddy/skills/    | inferred from global convention
#   openclaw    | .openclaw/skills/     | inferred from global convention
#   hermes      | .hermes/skills/       | inferred from global convention
#   teamwork    | teamwork/skills/      | inferred from global convention
#
resolve_project_agent_path() {
  local name="$1"
  case "$name" in
    .agents)       echo ".agents/skills" ;;
    opencode)      echo ".opencode/skills" ;;
    claude)        echo ".claude/skills" ;;
    cursor)        echo ".cursor/skills" ;;
    windsurf)      echo ".windsurf/skills" ;;
    trae)          echo ".trae/skills" ;;
    trae-cn)       echo ".trae-cn/skills" ;;
    codex)         echo ".codex/skills" ;;
    qoder)         echo ".qoder/skills" ;;
    qoderwork)     echo ".qoderwork/skills" ;;
    qoderworkcn)   echo ".qoderworkcn/skills" ;;
    workbuddy)     echo ".workbuddy/skills" ;;
    openclaw)      echo ".openclaw/skills" ;;
    hermes)        echo ".hermes/skills" ;;
    teamwork)      echo "teamwork/skills" ;;
    *)             echo "" ;;
  esac
}

# Check known agent directories and print a formatted table
detect_agents() {
  local found=0
  for entry in \
    ".agents:$HOME/.agents/skills" \
    "opencode:$HOME/.config/opencode/skills" \
    "claude:$HOME/.claude/skills" \
    "trae:$HOME/.trae/skills" \
    "trae-cn:$HOME/.trae-cn/skills" \
    "qoder:$HOME/.qoder/skills" \
    "qoderwork:$HOME/.qoderwork/skills" \
    "qoderworkcn:$HOME/.qoderworkcn/skills" \
    "workbuddy:$HOME/.workbuddy/skills" \
    "codex:$HOME/.codex/skills" \
    "openclaw:$HOME/.openclaw/skills" \
    "hermes:$HOME/.hermes/skills" \
    "teamwork:$HOME/teamwork/skills" \
    "cursor:$HOME/.cursor/skills" \
    "windsurf:$HOME/.windsurf/skills"; do

    local name="${entry%%:*}"
    local path="${entry#*:}"

    if [[ -d "$path" ]]; then
      found=$((found + 1))
      local count=0
      for d in "$path"/*/; do
        local bn; bn="$(basename "$d")"
        [[ "$bn" != _* ]] && count=$((count + 1))
      done

      local kind="dir"
      [[ -L "$path" ]] && kind="symlink"

      printf "  \033[1m%-16s\033[0m %s  (\033[33m%d\033[0m skills, %s)\n" \
        "$name" "$path" "$count" "$kind"
    fi
  done

  if [[ $found -eq 0 ]]; then
    return 1
  fi
  echo ""
  print_ok "$found agent(s) detected"
}

# Check project-level agent skill directories
detect_project_agents() {
  local found=0
  for entry in \
    ".agents:.agents/skills" \
    "opencode:.opencode/skills" \
    "claude:.claude/skills" \
    "cursor:.cursor/skills" \
    "windsurf:.windsurf/skills" \
    "trae:.trae/skills" \
    "trae-cn:.trae-cn/skills" \
    "codex:.codex/skills" \
    "qoder:.qoder/skills" \
    "qoderwork:.qoderwork/skills" \
    "qoderworkcn:.qoderworkcn/skills" \
    "workbuddy:.workbuddy/skills" \
    "openclaw:.openclaw/skills" \
    "hermes:.hermes/skills" \
    "teamwork:teamwork/skills"; do

    local name="${entry%%:*}"
    local rel_path="${entry#*:}"

    if [[ -d "$rel_path" || -L "$rel_path" ]]; then
      found=$((found + 1))
      local count=0
      local scan_dir="$rel_path"
      [[ -L "$rel_path" ]] && scan_dir="$(readlink "$rel_path")"
      if [[ -d "$scan_dir" ]]; then
        for d in "$scan_dir"/*/; do
          local bn; bn="$(basename "$d")"
          [[ "$bn" != _* ]] && count=$((count + 1))
        done
      fi

      local kind="dir"
      [[ -L "$rel_path" ]] && kind="symlink → $(readlink "$rel_path")"

      printf "  \033[1m%-16s\033[0m %s  (\033[33m%d\033[0m skills, %s)\n" \
        "$name" "$rel_path" "$count" "$kind"
    fi
  done

  if [[ $found -eq 0 ]]; then
    return 1
  fi
  echo ""
  print_ok "$found project agent(s) detected"
}

cmd_agents() {
  printf "\033[1mDetected Agent Skill Directories\033[0m\n"
  echo ""
  detect_agents || print_warn "No agent skill directories detected on this machine"
}

cmd_project_agents() {
  printf "\033[1mProject Agent Skill Directories\033[0m\n"
  echo ""
  detect_project_agents || print_warn "No project-level agent skill directories found in $(pwd)"
}

cmd_install_to() {
  local agent_name="${1:-}"
  local skill_name="${2:-}"

  if [[ -z "$agent_name" || -z "$skill_name" ]]; then
    print_error "Usage: pks install-to <agent-name> <skill-name>"
    print_info "Run 'pks agents' to see available agents"
    return 1
  fi

  local agent_path; agent_path="$(resolve_agent_path "$agent_name")"
  if [[ -z "$agent_path" ]]; then
    print_error "Unknown agent '$agent_name'"
    print_info "Known agents:"
    for e in .agents opencode claude trae trae-cn qoder qoderwork qoderworkcn workbuddy codex openclaw hermes teamwork cursor windsurf; do
      local p="$(resolve_agent_path "$e")"
      printf "  %s → %s\n" "$e" "$p"
    done
    return 1
  fi

  if [[ ! -d "$agent_path" ]]; then
    mkdir -p "$agent_path"
    print_info "Created $agent_path"
  fi

  local src="$SKILLS_DIR/$skill_name"
  if [[ ! -d "$src" ]]; then
    print_error "Skill '$skill_name' not found in global skills"
    print_info "Available:"
    cmd_list
    return 1
  fi

  local dest="$agent_path/$skill_name"
  if [[ -d "$dest" || -L "$dest" ]]; then
    print_warn "Skill '$skill_name' already exists in '$agent_name'"
    return 0
  fi

  cp -R "$src/" "$dest/"
  print_ok "Installed skill '$skill_name' → $agent_name ($agent_path)"
}

cmd_update_to() {
  local agent_name="${1:-}"
  local skill_name="${2:-}"

  if [[ -z "$agent_name" || -z "$skill_name" ]]; then
    print_error "Usage: pks update-to <agent-name> <skill-name>"
    print_info "Run 'pks agents' to see available agents"
    return 1
  fi

  local agent_path; agent_path="$(resolve_agent_path "$agent_name")"
  if [[ -z "$agent_path" ]]; then
    print_error "Unknown agent '$agent_name'"
    print_info "Known agents:"
    for e in .agents opencode claude trae trae-cn qoder qoderwork qoderworkcn workbuddy codex openclaw hermes teamwork cursor windsurf; do
      local p="$(resolve_agent_path "$e")"
      printf "  %s → %s\n" "$e" "$p"
    done
    return 1
  fi

  local src="$SKILLS_DIR/$skill_name"
  if [[ ! -d "$src" ]]; then
    print_error "Skill '$skill_name' not found in global skills"
    print_info "Available:"
    cmd_list
    return 1
  fi

  if [[ ! -d "$agent_path" ]]; then
    print_error "Agent '$agent_name' has no skill directory at $agent_path"
    return 1
  fi

  local dest="$agent_path/$skill_name"
  if [[ ! -d "$dest" && ! -L "$dest" ]]; then
    print_error "Skill '$skill_name' is not installed in '$agent_name'"
    print_info "Install it first: pks install-to $agent_name $skill_name"
    return 1
  fi

  rm -rf "$dest"
  cp -R "$src/" "$dest/"
  print_ok "Updated skill '$skill_name' in $agent_name ($agent_path)"
}

cmd_uninstall_from() {
  local agent_name="${1:-}"
  local skill_name="${2:-}"

  if [[ -z "$agent_name" || -z "$skill_name" ]]; then
    print_error "Usage: pks uninstall-from <agent-name> <skill-name>"
    print_info "Run 'pks agents' to see available agents"
    return 1
  fi

  local agent_path; agent_path="$(resolve_agent_path "$agent_name")"
  if [[ -z "$agent_path" ]]; then
    print_error "Unknown agent '$agent_name'"
    print_info "Known agents:"
    for e in .agents opencode claude trae trae-cn qoder qoderwork qoderworkcn workbuddy codex openclaw hermes teamwork cursor windsurf; do
      local p="$(resolve_agent_path "$e")"
      printf "  %s → %s\n" "$e" "$p"
    done
    return 1
  fi

  if [[ ! -d "$agent_path" ]]; then
    print_error "Agent '$agent_name' has no skill directory at $agent_path"
    return 1
  fi

  local dest="$agent_path/$skill_name"
  if [[ ! -d "$dest" && ! -L "$dest" ]]; then
    print_error "Skill '$skill_name' is not installed in '$agent_name'"
    return 1
  fi

  rm -rf "$dest"
  print_ok "Uninstalled skill '$skill_name' from $agent_name ($agent_path)"
}

# ---- project-level skill symlink commands ----------------------------------

cmd_link() {
  local agent_name="${1:-}"

  ensure_in_project || return 1

  if [[ -n "$agent_name" ]]; then
    # Link single agent
    local rel_path; rel_path="$(resolve_project_agent_path "$agent_name")"
    if [[ -z "$rel_path" ]]; then
      print_error "Unknown agent '$agent_name'"
      print_info "Known agents:"
      for e in .agents opencode claude trae trae-cn qoder qoderwork qoderworkcn workbuddy codex openclaw hermes teamwork cursor windsurf; do
        local p="$(resolve_project_agent_path "$e")"
        printf "  %s → %s\n" "$e" "$p"
      done
      return 1
    fi
    _link_one "$agent_name" "$rel_path"
  else
    # Link all known project agents
    local linked=0
    for entry in \
      ".agents:.agents/skills" \
      "opencode:.opencode/skills" \
      "claude:.claude/skills" \
      "cursor:.cursor/skills" \
      "windsurf:.windsurf/skills" \
      "trae:.trae/skills" \
      "trae-cn:.trae-cn/skills" \
      "codex:.codex/skills" \
      "qoder:.qoder/skills" \
      "qoderwork:.qoderwork/skills" \
      "qoderworkcn:.qoderworkcn/skills" \
      "workbuddy:.workbuddy/skills" \
      "openclaw:.openclaw/skills" \
      "hermes:.hermes/skills" \
      "teamwork:teamwork/skills"; do
      local name="${entry%%:*}"
      local path="${entry#*:}"
      if _link_one "$name" "$path"; then
        linked=$((linked + 1))
      fi
    done
    if [[ $linked -gt 0 ]]; then
      echo ""
      print_ok "Linked $linked agent(s) → $PROJECT_SKILLS_DIR"
    fi
  fi
}

_link_one() {
  local name="$1"
  local rel_path="$2"

  if [[ -L "$rel_path" ]]; then
    local current_target; current_target="$(readlink "$rel_path")"
    if [[ "$current_target" == "$PROJECT_SKILLS_DIR" ]]; then
      print_ok "[$name] $rel_path → $PROJECT_SKILLS_DIR (already linked)"
      return 0
    fi
    print_warn "[$name] $rel_path → $current_target (different target, skipping)"
    print_info "  Remove it first: rm '$rel_path'"
    return 1
  fi

  if [[ -d "$rel_path" ]]; then
    print_warn "[$name] $rel_path is a real directory (not a symlink), skipping"
    print_info "  Remove it first: rm -rf '$rel_path'"
    return 1
  fi

  # Ensure parent dir exists
  mkdir -p "$(dirname "$rel_path")"
  ln -s "$PROJECT_SKILLS_DIR" "$rel_path"
  print_ok "[$name] $rel_path → $PROJECT_SKILLS_DIR"
  return 0
}

cmd_unlink() {
  local agent_name="${1:-}"

  if [[ -n "$agent_name" ]]; then
    local rel_path; rel_path="$(resolve_project_agent_path "$agent_name")"
    if [[ -z "$rel_path" ]]; then
      print_error "Unknown agent '$agent_name'"
      return 1
    fi
    _unlink_one "$agent_name" "$rel_path"
  else
    # Unlink all
    local unlinked=0
    for entry in \
      ".agents:.agents/skills" \
      "opencode:.opencode/skills" \
      "claude:.claude/skills" \
      "cursor:.cursor/skills" \
      "windsurf:.windsurf/skills" \
      "trae:.trae/skills" \
      "trae-cn:.trae-cn/skills" \
      "codex:.codex/skills" \
      "qoder:.qoder/skills" \
      "qoderwork:.qoderwork/skills" \
      "qoderworkcn:.qoderworkcn/skills" \
      "workbuddy:.workbuddy/skills" \
      "openclaw:.openclaw/skills" \
      "hermes:.hermes/skills" \
      "teamwork:teamwork/skills"; do
      local name="${entry%%:*}"
      local path="${entry#*:}"
      if _unlink_one "$name" "$path"; then
        unlinked=$((unlinked + 1))
      fi
    done
    if [[ $unlinked -gt 0 ]]; then
      echo ""
      print_ok "Unlinked $unlinked agent(s)"
    fi
  fi
}

_unlink_one() {
  local name="$1"
  local rel_path="$2"

  if [[ ! -L "$rel_path" ]]; then
    if [[ -e "$rel_path" ]]; then
      print_info "[$name] $rel_path is not a symlink, skipping"
    fi
    return 1
  fi

  rm "$rel_path"
  print_ok "[$name] removed symlink $rel_path"

  # Clean up empty parent dirs
  local parent; parent="$(dirname "$rel_path")"
  [[ -d "$parent" && -z "$(ls -A "$parent" 2>/dev/null)" ]] && rmdir "$parent" 2>/dev/null
  return 0
}

# ---- main ------------------------------------------------------------------
main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    list|ls)           cmd_list "$@" ;;
    new|create)        cmd_new "${1:-}" ;;
    delete|remove|rm)  cmd_delete "${1:-}" ;;
    init)              cmd_init "$@" ;;
    available|avail|av) cmd_available "$@" ;;
    status|st)         cmd_status "$@" ;;
    install|i)         cmd_install "${1:-}" ;;
    uninstall)         cmd_uninstall "${1:-}" ;;
    update|up)         cmd_update "${1:-}" ;;
    push)              cmd_push "${1:-}" ;;
    install-to|to-agent)   cmd_install_to "${1:-}" "${2:-}" ;;
    update-to|up-to-agent)       cmd_update_to "${1:-}" "${2:-}" ;;
    uninstall-from|from-agent)   cmd_uninstall_from "${1:-}" "${2:-}" ;;
    agents|agent-dirs)           cmd_agents "$@" ;;
    project-agents|proj-agents)  cmd_project_agents "$@" ;;
    link|symlink)                cmd_link "${1:-}" ;;
    unlink|unsymlink)            cmd_unlink "${1:-}" ;;
    install-self|self-install) cmd_install_self "$@" ;;
    doctor|diag)       cmd_doctor "$@" ;;
    help|--help|-h)    usage ;;
    version|--version|-v) version ;;
    *)
      [[ -n "$cmd" ]] && print_error "Unknown command: $cmd"
      usage
      return 1
      ;;
  esac
}

main "$@"
